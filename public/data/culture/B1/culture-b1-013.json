    {
      "arabic": "تَتَعَلَّمُ البِنْتُ الخِيَاطَةَ مِنْ أُمِّهَا.",
      "translation": "Djevojka uči šivanje od majke.",
      "translationEn": "The girl learns sewing from her mother."
    },
    {
      "arabic": "تَصْنَعُ الأُمُّ مَلَابِسَ جَمِيلَةً بِيَدَيْهَا.",
      "translation": "Majka šije lijepu odjeću rukama.",
      "translationEn": "The mother makes beautiful clothes with her hands."
    },
    {
      "arabic": "الصِّنَاعَاتُ اليَدَوِيَّةُ تُرَاثٌ قَدِيمٌ.",
      "translation": "Ručni radovi su stara baština.",
      "translationEn": "Handicrafts are an old heritage."
    },
    {
      "arabic": "تَبِيعُ النِّسَاءُ مَنْتُوجَاتِهِنَّ فِي السُّوقِ.",
      "translation": "Žene prodaju svoje proizvode na pijaci.",
      "translationEn": "Women sell their products at the market."
    }
  ],
