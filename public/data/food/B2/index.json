        ]
      }
    },
    {
      "id": "food-b2-002",
      "arabic": "الْمَنْسَفُ وَجْبَةٌ تَقْلِيدِيَّةٌ تَتَكَوَّنُ مِنَ اللَّحْمِ وَالْأُرْزِ وَاللَّبَنِ.",
