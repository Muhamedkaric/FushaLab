{
  "items": [
    {
      "id": "health-b1-001",
      "arabic": "شَعَرَ كَرِيمٌ بِأَلَمٍ فِي رَأْسِهِ وَذَهَبَ إِلَى الطَّبِيبِ.",
      "metadata": { "difficulty": 1, "tags": ["doctor", "headache", "medicine", "pharmacy"] }
    },
    {
      "id": "health-b1-002",
      "arabic": "أَكَلَتْ سَلْمَى خُضَرَوَاتٍ طَازَجَةً كُلَّ يَوْمٍ.",
      "metadata": { "difficulty": 1, "tags": ["healthy food", "vegetables", "nutrition"] }
    },
    {
      "id": "health-b1-003",
      "arabic": "يَذْهَبُ أَحْمَدُ إِلَى الْمَلْعَبِ كُلَّ صَبَاحٍ.",
      "metadata": { "difficulty": 1, "tags": ["exercise", "running", "sport", "morning"] }
    },
    {
      "id": "health-b1-004",
      "arabic": "مَرِضَ الطِّفْلُ يُوسُفُ وَبَقِيَ فِي الْبَيْتِ.",
      "metadata": { "difficulty": 1, "tags": ["sick child", "cold", "fever", "doctor"] }
    },
    {
      "id": "health-b1-005",
      "arabic": "تَنَامُ لَيْلَى ثَمَانِيَ سَاعَاتٍ كُلَّ لَيْلَةٍ.",
      "metadata": { "difficulty": 1, "tags": ["sleep", "rest", "health habits"] }
    },
    {
      "id": "health-b1-006",
      "arabic": "ذَهَبَتْ فَاطِمَةُ إِلَى الصَّيْدَلِيَّةِ لِشِرَاءِ دَوَاءٍ لِلسُّعَالِ.",
      "metadata": { "difficulty": 1, "tags": ["pharmacy", "cough", "medicine", "cold"] }
    },
    {
      "id": "health-b1-007",
      "arabic": "يَمْشِي عَلِيٌّ كُلَّ يَوْمٍ لِمُدَّةِ عِشْرِينَ دَقِيقَةً.",
      "metadata": { "difficulty": 1, "tags": ["walking", "exercise", "daily routine"] }
    },
    {
      "id": "health-b1-008",
      "arabic": "شَعَرَتْ نُورٌ بِأَلَمٍ فِي مَعِدَتِهَا بَعْدَ الْغَدَاءِ.",
      "metadata": { "difficulty": 1, "tags": ["stomach", "doctor", "diet", "advice"] }
    },
    {
      "id": "health-b1-009",
      "arabic": "يَشْرَبُ تَامِرٌ ثَمَانِيَةَ أَكْوَابٍ مِنَ الْمَاءِ كُلَّ يَوْمٍ.",
      "metadata": { "difficulty": 1, "tags": ["water", "hydration", "health habits"] }
    },
    {
      "id": "health-b1-010",
      "arabic": "أَصَابَ رِيحٌ بَارِدَةٌ سَارَةَ وَبَدَأَتْ تَعْطِسُ كَثِيرًا.",
      "metadata": { "difficulty": 1, "tags": ["cold", "rest", "tea", "home remedy"] }
    },
    {
      "id": "health-b1-011",
      "arabic": "يَأْكُلُ خَالِدٌ الْفَاكِهَةَ كُلَّ يَوْمٍ لِأَنَّهَا مُفِيدَةٌ لِلصِّحَّةِ.",
      "metadata": { "difficulty": 1, "tags": ["fruit", "nutrition", "immunity", "healthy habits"] }
    },
    {
      "id": "health-b1-012",
      "arabic": "لَمْ يَنَمْ مَازِنٌ جَيِّدًا لِأَنَّهُ كَانَ قَلِقًا.",
      "metadata": { "difficulty": 1, "tags": ["sleep", "phone", "rest", "routine"] }
    },
    {
      "id": "health-b1-013",
      "arabic": "اشْتَكَى رَامِيٌّ مِنْ أَلَمٍ فِي الظَّهْرِ.",
      "metadata": { "difficulty": 1, "tags": ["back pain", "exercise", "posture", "computer"] }
    },
    {
      "id": "health-b1-014",
      "arabic": "تَتَنَاوَلُ هِنْدٌ وَجْبَةَ الْإِفْطَارِ كُلَّ صَبَاحٍ.",
      "metadata": { "difficulty": 1, "tags": ["breakfast", "nutrition", "morning", "healthy habits"] }
    },
    {
      "id": "health-b1-015",
      "arabic": "أَحَسَّ وَلِيدٌ بِأَلَمٍ فِي حَلْقِهِ مُنْذُ الصَّبَاحِ.",
      "metadata": { "difficulty": 1, "tags": ["throat", "honey", "lemon", "doctor"] }
    },
    {
      "id": "health-b1-016",
      "arabic": "تَسْبَحُ مَرْيَمُ فِي الْمَسْبَحِ ثَلَاثَ مَرَّاتٍ فِي الْأُسْبُوعِ.",
      "metadata": { "difficulty": 1, "tags": ["swimming", "exercise", "muscles", "sport"] }
    },
    {
      "id": "health-b1-017",
      "arabic": "أَخَذَ سَامِيٌّ ابْنَهُ الصَّغِيرَ إِلَى الطَّبِيبِ لِلْفَحْصِ الدَّوْرِيِّ.",
      "metadata": { "difficulty": 1, "tags": ["check-up", "child health", "growth", "doctor"] }
    },
    {
      "id": "health-b1-018",
      "arabic": "لَا تُحِبُّ دِيمَةُ الْأَكْلَ السَّرِيعَ وَتَطْبُخُ فِي الْبَيْتِ دَائِمًا.",
      "metadata": { "difficulty": 1, "tags": ["cooking", "healthy food", "olive oil", "vegetables"] }
    },
    {
      "id": "health-b1-019",
      "arabic": "يَلْعَبُ جَابِرٌ كُرَةَ الْقَدَمِ مَعَ أَصْدِقَائِهِ كُلَّ جُمْعَةٍ.",
      "metadata": { "difficulty": 1, "tags": ["football", "sport", "friends", "exercise"] }
    },
    {
      "id": "health-b1-020",
      "arabic": "ذَهَبَتْ رَنَا إِلَى الصَّيْدَلِيَّةِ لِتَشْتَرِيَ دَوَاءً لِلصُّدَاعِ.",
      "metadata": { "difficulty": 1, "tags": ["headache", "pharmacy", "medicine", "rest"] }
    },
    {
      "id": "health-b1-021",
      "arabic": "تَشْرَبُ أَمِيرَةُ فِنْجَانَ قَهْوَةٍ وَاحِدَةً فِي الصَّبَاحِ فَقَطْ.",
      "metadata": { "difficulty": 1, "tags": ["coffee", "green tea", "sleep", "doctor advice"] }
    },
    {
      "id": "health-b1-022",
      "arabic": "سَقَطَ الطِّفْلُ حَسَنٌ مِنَ الدَّرَّاجَةِ وَجُرِحَتْ رُكْبَتُهُ.",
      "metadata": { "difficulty": 1, "tags": ["injury", "child", "first aid", "bandage"] }
    },
    {
      "id": "health-b1-023",
      "arabic": "تَتَمَدَّدُ يَسْمِينُ كُلَّ صَبَاحٍ لِمُدَّةِ خَمْسَ عَشْرَةَ دَقِيقَةً.",
      "metadata": { "difficulty": 1, "tags": ["stretching", "exercise", "back pain", "morning"] }
    },
    {
      "id": "health-b1-024",
      "arabic": "اشْتَكَتِ الْبِنْتُ لَمَى مِنْ أَلَمٍ فِي أُذُنِهَا.",
      "metadata": { "difficulty": 1, "tags": ["ear pain", "child", "doctor", "medicine"] }
    },
    {
      "id": "health-b1-025",
      "arabic": "يَتَجَنَّبُ نَادِرٌ الْأَكْلَ كَثِيرًا فِي اللَّيْلِ.",
      "metadata": { "difficulty": 1, "tags": ["dinner", "digestion", "night eating", "healthy habits"] }
    },
    {
      "id": "health-b1-026",
      "arabic": "تَزُورُ هَاجِرُ طَبِيبَهَا مَرَّةً كُلَّ سِتَّةِ أَشْهُرٍ.",
      "metadata": { "difficulty": 1, "tags": ["check-up", "blood pressure", "prevention", "doctor"] }
    },
    {
      "id": "health-b1-027",
      "arabic": "قَرَّرَ بِلَالٌ أَنْ يَتَوَقَّفَ عَنِ السُّكَّرِيَّاتِ لِشَهْرٍ.",
      "metadata": { "difficulty": 1, "tags": ["sugar", "diet", "healthy habits", "fruit"] }
    },
    {
      "id": "health-b1-028",
      "arabic": "كَانَتِ الطِّفْلَةُ سُكَيْنَةُ مَرِيضَةً وَلَمْ تَنَمْ جَيِّدًا.",
      "metadata": { "difficulty": 1, "tags": ["sick child", "fever", "mother", "medicine"] }
    },
    {
      "id": "health-b1-029",
      "arabic": "يَرْكَبُ إِبْرَاهِيمُ الدَّرَّاجَةَ لِلذِّهَابِ إِلَى الْعَمَلِ.",
      "metadata": { "difficulty": 1, "tags": ["bicycle", "exercise", "commute", "healthy habits"] }
    },
    {
      "id": "health-b1-030",
      "arabic": "اشْتَرَتْ مَيْسُونُ مِنَ الصَّيْدَلِيَّةِ كَرِيمًا لِلْجِلْدِ الْجَافِّ.",
      "metadata": { "difficulty": 1, "tags": ["skin care", "pharmacy", "cream", "daily routine"] }
    },
    {
      "id": "health-b1-031",
      "arabic": "يُحِبُّ طَارِقٌ الْيُوغَا وَيُمَارِسُهَا كُلَّ مَسَاءٍ.",
      "metadata": { "difficulty": 1, "tags": ["yoga", "relaxation", "evening routine", "exercise"] }
    },
    {
      "id": "health-b1-032",
      "arabic": "شَعَرَ عِمَادٌ بِدُوَارٍ وَجَلَسَ عَلَى الْأَرِيكَةِ.",
      "metadata": { "difficulty": 1, "tags": ["dizziness", "hunger", "eating", "quick remedy"] }
    },
    {
      "id": "health-b1-033",
      "arabic": "قَرَّرَتْ شَيْمَاءُ أَنْ تَبْدَأَ بِالتَّمَارِينِ لِأَوَّلِ مَرَّةٍ.",
      "metadata": { "difficulty": 1, "tags": ["gym", "beginner", "exercise", "trainer"] }
    },
    {
      "id": "health-b1-034",
      "arabic": "يَأْكُلُ مُحَمَّدٌ السَّلَطَةَ مَعَ كُلِّ وَجْبَةٍ.",
      "metadata": { "difficulty": 1, "tags": ["salad", "nutrition", "olive oil", "weight"] }
    },
    {
      "id": "health-b1-035",
      "arabic": "شَعَرَتْ زَيْنَبُ بِأَلَمٍ فِي أَسْنَانِهَا وَلَمْ تَسْتَطِعِ النَّوْمَ.",
      "metadata": { "difficulty": 1, "tags": ["toothache", "dentist", "teeth", "hygiene"] }
    },
    {
      "id": "health-b1-036",
      "arabic": "يَحْمِلُ عِصَامٌ مَعَهُ وَجْبَةً خَفِيفَةً صِحِّيَّةً إِلَى الْعَمَلِ.",
      "metadata": { "difficulty": 1, "tags": ["snack", "nuts", "healthy eating", "work"] }
    },
    {
      "id": "health-b1-037",
      "arabic": "أَصِيبَ الْوَلَدُ سَعِيدٌ بِسُعَالٍ شَدِيدٍ فِي اللَّيْلِ.",
      "metadata": { "difficulty": 1, "tags": ["cough", "night", "medicine", "child"] }
    },
    {
      "id": "health-b1-038",
      "arabic": "تَغْسِلُ لُجَيْنُ يَدَيْهَا قَبْلَ كُلِّ وَجْبَةٍ.",
      "metadata": { "difficulty": 1, "tags": ["hygiene", "hand washing", "prevention", "healthy habits"] }
    },
    {
      "id": "health-b1-039",
      "arabic": "قَرَّرَ وَائِلٌ أَنْ يَمْشِيَ بَدَلَ رُكُوبِ السَّيَّارَةِ.",
      "metadata": { "difficulty": 1, "tags": ["walking", "weight loss", "daily routine", "exercise"] }
    },
    {
      "id": "health-b1-040",
      "arabic": "اشْتَرَتْ سُهَيْلَةُ مِنَ الصَّيْدَلِيَّةِ فِيتَامِينَاتٍ لِلشِّتَاءِ.",
      "metadata": { "difficulty": 1, "tags": ["vitamins", "pharmacy", "winter", "prevention"] }
    },
    {
      "id": "health-b1-041",
      "arabic": "أَحَسَّ فِرَاسٌ بِإِرْهَاقٍ شَدِيدٍ بَعْدَ أُسْبُوعٍ طَوِيلٍ مِنَ الْعَمَلِ.",
      "metadata": { "difficulty": 1, "tags": ["exhaustion", "rest", "recovery", "fresh air"] }
    },
    {
      "id": "health-b1-042",
      "arabic": "تَتَجَنَّبُ غَادَةُ الطَّعَامَ الْمَقْلِيَّ وَتُفَضِّلُ الْمَشْوِيَّ.",
      "metadata": { "difficulty": 1, "tags": ["cooking", "grilled", "fried food", "nutrition"] }
    },
    {
      "id": "health-b1-043",
      "arabic": "عَطَسَ زَيْدٌ كَثِيرًا فِي الصَّبَاحِ وَسَالَ أَنْفُهُ.",
      "metadata": { "difficulty": 1, "tags": ["cold", "runny nose", "pharmacy", "drops"] }
    },
    {
      "id": "health-b1-044",
      "arabic": "تَحْرِصُ مَنَالٌ عَلَى شُرْبِ الْحَلِيبِ كُلَّ يَوْمٍ.",
      "metadata": { "difficulty": 1, "tags": ["milk", "calcium", "bones", "breakfast"] }
    },
    {
      "id": "health-b1-045",
      "arabic": "جَاءَ حَازِمٌ إِلَى الصَّيْدَلِيَّةِ لِيَشْتَرِيَ دَوَاءً لِأُمِّهِ.",
      "metadata": { "difficulty": 1, "tags": ["pharmacy", "prescription", "medicine", "family"] }
    }
  ]
}
