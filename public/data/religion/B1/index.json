          "repentance",
          "hadith",
          "mercy"
        ]
      }
    },
    {
      "id": "religion-b1-011",
      "arabic": "الْإِخْلَاصُ شَرْطٌ لِقَبُولِ الْعَمَلِ عِنْدَ اللَّهِ تَعَالَى.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "ikhlas",
          "sincerity",
          "hadith",
          "niyyah"
        ]
      }
    },
    {
      "id": "religion-b1-012",
      "arabic": "التَّوَكُّلُ عَلَى اللَّهِ لَا يَعْنِي تَرْكَ الْعَمَلِ وَالْأَخْذَ بِالْأَسْبَابِ.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "tawakkul",
          "reliance",
          "hadith"
        ]
      }
    },
    {
      "id": "religion-b1-013",
      "arabic": "بِرُّ الْوَالِدَيْنِ مِنْ أَعْظَمِ الْوَاجِبَاتِ فِي الْإِسْلَامِ.",
      "metadata": {
        "difficulty": 1,
