        ]
      }
    },
    {
      "id": "religion-b1-023",
      "arabic": "الصِّدْقُ خُلُقٌ كَرِيمٌ أَمَرَ بِهِ الْإِسْلَامُ وَحَثَّ عَلَيْهِ.",
