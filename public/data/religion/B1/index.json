    },
    {
      "id": "religion-b1-029",
      "arabic": "حُسْنُ الظَّنِّ بِاللَّهِ تَعَالَى مِنْ أُصُولِ الْعَقِيدَةِ الصَّحِيحَةِ.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "husn-al-zann",
          "aqeedah",
