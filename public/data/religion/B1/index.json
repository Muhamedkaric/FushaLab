          "dhikr"
        ]
      }
    },
    {
      "id": "religion-b1-027",
      "arabic": "الصَّدَقَةُ عِبَادَةٌ يُحِبُّهَا اللَّهُ وَتُطْفِئُ غَضَبَهُ.",
      "metadata": {
        "difficulty": 1,
