          "hadith"
        ]
      }
    },
    {
      "id": "religion-b1-010",
      "arabic": "التَّوْبَةُ بَابٌ مَفْتُوحٌ لِكُلِّ عَبْدٍ يَرْجِعُ إِلَى اللَّهِ.",
      "metadata": {
        "difficulty": 1,
