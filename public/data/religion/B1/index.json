        ]
      }
    },
    {
      "id": "religion-b1-035",
      "arabic": "التَّوَكُّلُ عَلَى اللَّهِ هُوَ اعْتِمَادُ الْقَلْبِ عَلَى اللَّهِ مَعَ الْأَخْذِ",
      "metadata": {
