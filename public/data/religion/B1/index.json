    },
    {
      "id": "religion-b1-042",
      "arabic": "تَعَلَّمَ الصَّحَابَةُ الْكِرَامُ آدَابَ الطَّعَامِ مِنَ الرَّسُولِ صَلَّى اللهُ عَلَيْهِ",
