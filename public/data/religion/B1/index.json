          "bilal",
          "sabr",
          "tawhid"
        ]
      }
    },
    {
      "id": "religion-b1-008",
      "arabic": "الْآدَابُ الْإِسْلَامِيَّةُ جُزْءٌ مِنَ الدِّينِ وَلَيْسَتْ زِيَادَةً عَلَيْهِ.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "adab",
          "manners",
          "hadith",
          "character"
        ]
      }
    },
    {
      "id": "religion-b1-009",
      "arabic": "ذِكْرُ اللَّهِ تَعَالَى غِذَاءُ الْقُلُوبِ وَطُمَأْنِينَتُهَا.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "dhikr",
