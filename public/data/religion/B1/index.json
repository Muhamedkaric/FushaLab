          "hadith"
        ]
      }
    },
    {
      "id": "religion-b1-030",
      "arabic": "الدُّعَاءُ عِبَادَةٌ عَظِيمَةٌ وَهُوَ مُخُّ الْعِبَادَةِ كَمَا قَالَ النَّبِيُّ صَلَّى",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "dua",
          "supplication",
          "dhikr",
          "ibadah"
        ]
      }
    },
    {
      "id": "religion-b1-031",
      "arabic": "عَنْ عُمَرَ بْنِ الْخَطَّابِ رَضِيَ اللَّهُ عَنْهُ، قَالَ النَّبِيُّ صَلَّى",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "Ikhlas",
          "Hadith",
          "Intentions"
        ]
      }
    },
    {
      "id": "religion-b1-032",
      "arabic": "قَالَ النَّبِيُّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ: «عَلَيْكُمْ بِالصِّدْقِ، فَإِنَّ الصِّدْقَ",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "Adab",
          "Hadith",
          "Honesty"
        ]
      }
    },
    {
      "id": "religion-b1-033",
      "arabic": "الصَّلَاةُ هِيَ الرُّكْنُ الثَّانِي مِنْ أَرْكَانِ الْإِسْلَامِ الْخَمْسَةِ الْعَظِيمَةِ.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "Salah",
          "Hadith",
          "Pillars of Islam"
        ]
      }
    },
    {
      "id": "religion-b1-034",
      "arabic": "جَاءَ رَجُلٌ إِلَى النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ يَسْتَأْذِنُهُ فِي",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "Birr al-Walidayn",
