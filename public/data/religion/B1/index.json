    {
      "id": "religion-b1-040",
      "arabic": "أَبُو بَكْرٍ الصِّدِّيقُ هُوَ أَفْضَلُ الصَّحَابَةِ بَعْدَ الْأَنْبِيَاءِ.",
      "metadata": {
