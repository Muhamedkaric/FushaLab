          "hadith",
          "adab"
        ]
      }
    },
    {
      "id": "religion-b1-014",
      "arabic": "الصَّبْرُ خُلُقٌ عَظِيمٌ يُحِبُّهُ اللَّهُ وَيُثِيبُ عَلَيْهِ.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "sabr",
          "patience",
          "hadith"
        ]
      }
    },
    {
      "id": "religion-b1-015",
      "arabic": "الْكَرَمُ وَالسَّخَاءُ مِنْ أَبْرَزِ صِفَاتِ النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "generosity",
          "seerah",
          "hadith",
          "character"
        ]
      }
    },
    {
      "id": "religion-b1-016",
      "arabic": "الرَّحْمَةُ صِفَةٌ يُحِبُّهَا اللَّهُ فِي عِبَادِهِ.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "mercy",
          "hadith",
          "character",
          "seerah"
        ]
      }
    },
    {
      "id": "religion-b1-017",
      "arabic": "عُمَرُ بْنُ الْخَطَّابِ رَضِيَ اللَّهُ عَنْهُ كَانَ مَعْرُوفًا بِعَدْلِهِ وَزُهْدِهِ.",
      "metadata": {
        "difficulty": 1,
        "tags": [
