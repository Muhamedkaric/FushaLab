    },
    {
      "id": "religion-b1-039",
      "arabic": "النِّيَّةُ الصَّالِحَةُ هِيَ أَسَاسُ قَبُولِ الْأَعْمَالِ عِنْدَ اللهِ.",
      "metadata": {
        "difficulty": 1,
