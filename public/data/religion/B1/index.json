    },
    {
      "id": "religion-b1-028",
      "arabic": "خَدِيجَةُ بِنْتُ خُوَيْلِدٍ رَضِيَ اللَّهُ عَنْهَا كَانَتْ أَوَّلَ مَنْ آمَنَ",
