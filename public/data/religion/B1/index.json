          "umar",
          "leadership",
          "seerah"
        ]
      }
    },
    {
      "id": "religion-b1-018",
      "arabic": "الْحَلَالُ وَالْحَرَامُ حُدُودٌ رَسَمَهَا اللَّهُ لِحِمَايَةِ الْإِنْسَانِ.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "halal",
          "haram",
          "fiqh",
          "hadith"
        ]
      }
    },
    {
      "id": "religion-b1-019",
      "arabic": "هِجْرَةُ النَّبِيِّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ مِنْ مَكَّةَ إِلَى الْمَدِينَةِ",
      "metadata": {
        "difficulty": 1,
