          "tawakkul"
        ]
      }
    },
    {
      "id": "religion-b1-020",
      "arabic": "عُثْمَانُ بْنُ عَفَّانَ رَضِيَ اللَّهُ عَنْهُ كَانَ مَعْرُوفًا بِسَخَائِهِ الْعَظِيمِ",
      "metadata": {
