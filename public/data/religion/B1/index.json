{
  "items": [
    {
      "id": "religion-b1-001",
      "arabic": "التَّوْحِيدُ هُوَ أَسَاسُ الدِّينِ الْإِسْلَامِيِّ.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "tawhid",
          "aqeedah",
          "hadith"
        ]
      }
    },
    {
      "id": "religion-b1-002",
      "arabic": "الصَّلَاةُ عِمَادُ الدِّينِ، وَهِيَ أَوَّلُ مَا يُحَاسَبُ عَلَيْهِ الْعَبْدُ يَوْمَ",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "salah",
          "prayer",
          "hadith"
        ]
      }
    },
    {
      "id": "religion-b1-003",
      "arabic": "الزَّكَاةُ رُكْنٌ مِنْ أَرْكَانِ الْإِسْلَامِ، وَهِيَ حَقُّ الْفُقَرَاءِ فِي أَمْوَالِ",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "zakah",
          "hadith",
          "pillars"
        ]
      }
    },
    {
      "id": "religion-b1-004",
      "arabic": "الصَّوْمُ عِبَادَةٌ عَظِيمَةٌ يَتَقَرَّبُ بِهَا الْمُسْلِمُ إِلَى اللَّهِ تَعَالَى.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "sawm",
          "fasting",
          "ramadan",
          "hadith"
        ]
      }
    },
    {
      "id": "religion-b1-005",
      "arabic": "الْحَجُّ فَرِيضَةٌ عَلَى كُلِّ مُسْلِمٍ مُسْتَطِيعٍ مَرَّةً وَاحِدَةً فِي الْعُمُرِ.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "hajj",
          "pillars",
          "hadith"
        ]
      }
    },
    {
      "id": "religion-b1-006",
      "arabic": "أَبُو بَكْرٍ الصِّدِّيقُ رَضِيَ اللَّهُ عَنْهُ كَانَ أَوَّلَ مَنْ آمَنَ",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "companions",
          "abu-bakr",
          "seerah"
        ]
      }
    },
    {
      "id": "religion-b1-007",
      "arabic": "بِلَالُ بْنُ رَبَاحٍ رَضِيَ اللَّهُ عَنْهُ كَانَ عَبْدًا حَبَشِيًّا آمَنَ",
      "metadata": {
        "difficulty": 1,
        "tags": [
