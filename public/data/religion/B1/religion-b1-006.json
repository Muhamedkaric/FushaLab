  "sentences": [
    {
      "arabic": "يُحِبُّ إِبْرَاهِيمُ أَنْ يُسَاعِدَ جِيرَانَهُ.",
      "translation": "Ibrahim voli pomagati komšijama.",
      "translationEn": "Ibrahim loves to help his neighbors."
    },
    {
      "arabic": "يَحْمِلُ الْأَشْيَاءَ الثَّقِيلَةَ لِلشَّيْخِ الْكَبِيرِ.",
      "translation": "Nosi teške stvari starcu.",
      "translationEn": "He carries heavy things for the elderly man."
    },
    {
      "arabic": "يَقُولُ: مُسَاعَدَةُ الْجَارِ مِنَ الدِّينِ.",
      "translation": "Kaže: Pomaganje komšiji je dio vjere.",
      "translationEn": "He says: Helping the neighbor is part of the religion."
    },
    {
      "arabic": "يَشْعُرُ بِالسَّعَادَةِ حِينَ يَفْعَلُ الْخَيْرَ.",
      "translation": "Osjeća sreću kad čini dobro.",
      "translationEn": "He feels happy when he does good."
    }
  ],
