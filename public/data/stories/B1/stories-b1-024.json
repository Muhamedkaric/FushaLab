  "sentences": [
    {
      "arabic": "كَانَ شَجَرُ التُّفَّاحِ فِي حَدِيقَةِ الْجَدِّ مَلِيئًا بِالثِّمَارِ.",
      "translation": "Stabla jabuka u djedinoj bašti su bila puna plodova.",
      "translationEn": "The apple trees in grandfather's garden were full of fruit.",
      "words": [
        { "w": "شَجَرُ", "root": "ش ج ر", "bs": "stabla", "en": "trees" },
