        { "w": "الْجَدُّ", "root": "ج د د", "bs": "djed", "en": "grandfather" },
        { "w": "حَفِيدُهُ", "root": "ح ف د", "bs": "njegov unuk", "en": "his grandson" },
        { "w": "التُّفَّاحَ", "root": "ت ف ح", "bs": "jabuke", "en": "apples" }
      ]
    },
    {
      "arabic": "أَخَذَا بَعْضَهُ لِلْجِيرَانِ وَبَعْضَهُ لِلْبَيْتِ.",
      "translation": "Dio su dali komšijama a dio za kuću.",
      "translationEn": "They took some for the neighbors and some for home.",
