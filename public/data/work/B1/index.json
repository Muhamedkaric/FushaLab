{
  "items": [
    {
      "id": "work-b1-001",
      "arabic": "وَصَلَ عُمَرُ إِلَى الْمَكْتَبِ فِي السَّاعَةِ الثَّامِنَةِ صَبَاحًا.",
      "metadata": { "difficulty": 1, "tags": ["office", "morning", "email", "arrival"] }
    },
    {
      "id": "work-b1-002",
      "arabic": "تَذْهَبُ سُوزَانُ إِلَى الْعَمَلِ كُلَّ يَوْمٍ بِالْحَافِلَةِ.",
      "metadata": { "difficulty": 1, "tags": ["commute", "bus", "morning", "routine"] }
    },
    {
      "id": "work-b1-003",
      "arabic": "طَلَبَ الْمُدِيرُ مِنْ خَالِدٍ تَقْرِيرًا بَسِيطًا عَنِ الْعَمَلِ.",
      "metadata": { "difficulty": 1, "tags": ["report", "manager", "office task", "writing"] }
    },
    {
      "id": "work-b1-004",
      "arabic": "تَنَاوَلَ الزُّمَلَاءُ غَدَاءَهُمْ مَعًا فِي غُرْفَةِ الِاسْتِرَاحَةِ.",
      "metadata": { "difficulty": 1, "tags": ["lunch", "colleagues", "break room", "teamwork"] }
    },
    {
      "id": "work-b1-005",
      "arabic": "انْتَهَتْ دِينَا مِنَ الْعَمَلِ فِي السَّاعَةِ الْخَامِسَةِ مَسَاءً.",
      "metadata": { "difficulty": 1, "tags": ["end of work", "office", "leaving", "routine"] }
    },
    {
      "id": "work-b1-006",
      "arabic": "طَلَبَ يَاسِرٌ مِنْ مُدِيرِهِ إِجَازَةً لِيَوْمٍ وَاحِدٍ.",
      "metadata": { "difficulty": 1, "tags": ["day off", "manager", "request", "office"] }
    },
    {
      "id": "work-b1-007",
      "arabic": "وَصَلَتْ رَسَالَةٌ جَدِيدَةٌ إِلَى بَرِيدِ هَبَةَ الْإِلِكْتُرُونِيِّ.",
      "metadata": { "difficulty": 1, "tags": ["email", "client", "appointment", "office communication"] }
    },
    {
      "id": "work-b1-008",
      "arabic": "يَصْحُو نَبِيلٌ فِي السَّاعَةِ السَّادِسَةِ وَيُعِدُّ نَفْسَهُ لِلْعَمَلِ.",
      "metadata": { "difficulty": 1, "tags": ["morning routine", "preparation", "punctuality", "work"] }
    },
    {
      "id": "work-b1-009",
      "arabic": "قَدِمَ مُوَظَّفٌ جَدِيدٌ اسْمُهُ فَيْصَلٌ إِلَى الشَّرِكَةِ.",
      "metadata": { "difficulty": 1, "tags": ["new employee", "welcome", "first day", "office"] }
    },
    {
      "id": "work-b1-010",
      "arabic": "سَأَلَ الْمُدِيرُ رِيمَ عَنْ سَيْرِ الْمَشْرُوعِ.",
      "metadata": { "difficulty": 1, "tags": ["project", "manager", "progress", "office"] }
    },
    {
      "id": "work-b1-011",
      "arabic": "يَعْمَلُ كَمَالٌ فِي مَتْجَرٍ لِبَيْعِ الْمَلَابِسِ.",
      "metadata": { "difficulty": 1, "tags": ["shop", "customer service", "clothing", "work"] }
    },
    {
      "id": "work-b1-012",
      "arabic": "طَلَبَ لُؤَيٌّ مِنْ زَمِيلِهِ أَنْ يُسَاعِدَهُ فِي مَهْمَّةٍ.",
      "metadata": { "difficulty": 1, "tags": ["teamwork", "colleagues", "task", "cooperation"] }
    },
    {
      "id": "work-b1-013",
      "arabic": "تَعْمَلُ وَفَاءُ مُعَلِّمَةً فِي مَدْرَسَةٍ ابْتِدَائِيَّةٍ.",
      "metadata": { "difficulty": 1, "tags": ["teacher", "school", "morning routine", "classroom"] }
    },
    {
      "id": "work-b1-014",
      "arabic": "أَخْطَأَ مَاجِدٌ فِي تَقْرِيرٍ وَأَخْبَرَ مُدِيرَهُ بِذَلِكَ.",
      "metadata": { "difficulty": 1, "tags": ["mistake", "honesty", "report", "manager"] }
    },
    {
      "id": "work-b1-015",
      "arabic": "يَعْمَلُ صَلَاحٌ طَبَّاخًا فِي مَطْعَمٍ صَغِيرٍ.",
      "metadata": { "difficulty": 1, "tags": ["cook", "restaurant", "kitchen", "food preparation"] }
    },
    {
      "id": "work-b1-016",
      "arabic": "اتَّصَلَ زَبُونٌ بِالشَّرِكَةِ وَطَلَبَ الْكَلَامَ مَعَ الْمَسْؤُولِ.",
      "metadata": { "difficulty": 1, "tags": ["phone call", "customer", "reception", "office"] }
    },
    {
      "id": "work-b1-017",
      "arabic": "أَنْهَتْ مَيَّادَةُ الْعَمَلَ وَشَعَرَتْ بِتَعَبٍ شَدِيدٍ.",
      "metadata": { "difficulty": 1, "tags": ["end of work", "colleagues", "tea break", "friendship"] }
    },
    {
      "id": "work-b1-018",
      "arabic": "طَلَبَ الْمُدِيرُ مِنَ الْفَرِيقِ حُضُورَ اجْتِمَاعٍ قَصِيرٍ.",
      "metadata": { "difficulty": 1, "tags": ["meeting", "team", "manager", "tasks"] }
    },
    {
      "id": "work-b1-019",
      "arabic": "تَعْمَلُ حَنَانُ فِي مَكْتَبَةٍ عَامَّةٍ فِي الْمَدِينَةِ.",
      "metadata": { "difficulty": 1, "tags": ["library", "books", "work", "public service"] }
    },
    {
      "id": "work-b1-020",
      "arabic": "نَسِيَ جَعْفَرٌ أَنْ يُرْسِلَ وَثِيقَةً مُهِمَّةً إِلَى الْمُدِيرِ.",
      "metadata": { "difficulty": 1, "tags": ["document", "email", "apology", "office"] }
    },
    {
      "id": "work-b1-021",
      "arabic": "يَعْمَلُ حَسَّانُ سَائِقَ تَاكْسِي فِي الْمَدِينَةِ.",
      "metadata": { "difficulty": 1, "tags": ["taxi driver", "transport", "morning shift", "city"] }
    },
    {
      "id": "work-b1-022",
      "arabic": "كَتَبَتْ رَنِيمُ قَائِمَةً بِمَهَامِّهَا فِي بِدَايَةِ كُلِّ يَوْمٍ.",
      "metadata": { "difficulty": 1, "tags": ["task list", "organisation", "productivity", "office"] }
    },
    {
      "id": "work-b1-023",
      "arabic": "جَاءَ مُفَتِّشٌ إِلَى الْمَكْتَبِ لِفَحْصِ الْأَوْرَاقِ.",
      "metadata": { "difficulty": 1, "tags": ["inspection", "documents", "organisation", "office"] }
    },
    {
      "id": "work-b1-024",
      "arabic": "يَعْمَلُ بَاسِلٌ حَارِسًا فِي مَبْنًى كَبِيرٍ.",
      "metadata": { "difficulty": 1, "tags": ["security guard", "night shift", "building", "routine"] }
    },
    {
      "id": "work-b1-025",
      "arabic": "تَعْمَلُ إِيمَانُ مُحَاسِبَةً فِي شَرِكَةٍ صَغِيرَةٍ.",
