          "office life",
          "productivity"
        ]
      }
    },
    {
      "id": "work-b1-010",
      "arabic": "قَرَّرَتْ سَارَةُ أَنْ تَفْتَحَ مَتْجَرًا صَغِيرًا لِلزُّهُورِ فِي الْمَدِينَةِ.",
