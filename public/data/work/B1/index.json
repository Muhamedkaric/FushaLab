    },
    {
      "id": "work-b1-041",
      "arabic": "تَعَلَّمَ شَادِيٌّ مَهَارَةً جَدِيدَةً فِي الْعَمَلِ.",
      "metadata": { "difficulty": 1, "tags": ["training", "skill", "online course", "improvement"] }
    },
    {
      "id": "work-b1-042",
      "arabic": "أَعْلَنَتِ الشَّرِكَةُ عَنْ مُوَظَّفِ الشَّهْرِ.",
      "metadata": { "difficulty": 1, "tags": ["employee of the month", "award", "recognition", "company"] }
    },
    {
      "id": "work-b1-043",
      "arabic": "يَعْمَلُ صَابِرٌ مُدَرِّبًا رِيَاضِيًّا فِي نَادٍ.",
