    },
    {
      "id": "work-b1-039",
      "arabic": "يَعْمَلُ حَيْدَرٌ مِيكَانِيكِيًّا فِي وَرْشَةِ سَيَّارَاتٍ.",
      "metadata": { "difficulty": 1, "tags": ["mechanic", "car workshop", "repair", "trust"] }
    },
    {
      "id": "work-b1-040",
      "arabic": "تَعْمَلُ أَسْمَاءُ مُصَمِّمَةً لِلْمَوَاقِعِ الْإِلِكْتُرُونِيَّةِ.",
