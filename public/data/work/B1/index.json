        ]
      }
    },
    {
      "id": "work-b1-002",
      "arabic": "تَبْدَأُ لَيْلَى عَمَلَهَا فِي السَّاعَةِ التَّاسِعَةِ صَبَاحًا.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "office life",
          "daily routine",
          "workplace"
        ]
      }
    },
    {
      "id": "work-b1-003",
      "arabic": "التَّعَاوُنُ بَيْنَ الْمُوَظَّفِينَ يُؤَدِّي إِلَى النَّجَاحِ.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "teamwork",
          "collaboration",
          "office environment"
        ]
      }
    },
    {
      "id": "work-b1-004",
      "arabic": "يَحْلُمُ سَامِي أَنْ يُصْبِحَ مُهَنْدِسًا مِعْمَارِيًّا فِي الْمُسْتَقْبَلِ.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "career choice",
          "professions",
          "education"
        ]
      }
    },
    {
      "id": "work-b1-005",
      "arabic": "تَنْظِيمُ الْوَقْتِ ضَرُورِيٌّ لِزِيَادَةِ الْإِنْتَاجِيَّةِ فِي الْعَمَلِ.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "productivity",
          "time management",
          "focus"
        ]
      }
    },
    {
      "id": "work-b1-006",
      "arabic": "ذَهَبْتُ إِلَى شَرِكَةٍ كَبِيرَةٍ أَمْسِ لِإِجْرَاءِ مُقَابَلَةِ عَمَلٍ.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "job interview",
          "careers",
          "professional skills"
        ]
      }
    },
    {
      "id": "work-b1-007",
      "arabic": "مَكْتَبِي الْجَدِيدُ مُضِيءٌ وَمُنَظَّمٌ جِدًّا.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "office life",
          "workplace",
          "productivity"
        ]
      }
    },
    {
      "id": "work-b1-008",
      "arabic": "يَعْمَلُ أَخِي مُعَلِّمًا فِي مَدْرَسَةٍ ثَانَوِيَّةٍ حُكُومِيَّةٍ.",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "professions",
          "education",
          "careers"
        ]
      }
    },
    {
      "id": "work-b1-009",
      "arabic": "عَمِلْنَا كَفَرِيقٍ وَاحِدٍ لِإِنْهَاءِ الْمَشْرُوعِ فِي الْوَقْتِ الْمُحَدَّدِ.",
      "metadata": {
        "difficulty": 1,
        "tags": [
