    {
      "id": "work-b1-001",
      "arabic": "ذَهَبَ أَحْمَدُ إِلَى مُقَابَلَةِ عَمَلٍ جَدِيدَةٍ صَبَاحَ الْيَوْمِ.",
      "metadata": {
