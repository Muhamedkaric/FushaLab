    },
    {
      "id": "work-b1-026",
      "arabic": "تَأَخَّرَ أَدْهَمُ عَنِ الْعَمَلِ بِسَبَبِ الزِّحَامِ فِي الطَّرِيقِ.",
      "metadata": { "difficulty": 1, "tags": ["late", "traffic", "manager", "punctuality"] }
    },
    {
      "id": "work-b1-027",
      "arabic": "تَعْمَلُ سَمِيَّةُ طَبِيبَةً فِي مُسْتَشْفَى قَرِيبٍ مِنَ الْبَيْتِ.",
      "metadata": { "difficulty": 1, "tags": ["doctor", "hospital", "patients", "work routine"] }
    },
    {
      "id": "work-b1-028",
      "arabic": "طَلَبَ مُدِيرُ الْقِسْمِ مِنْ عَامِرٍ أَنْ يُنَظِّمَ الْأَرْشِيفَ.",
      "metadata": { "difficulty": 1, "tags": ["archive", "organisation", "office task", "praise"] }
    },
    {
      "id": "work-b1-029",
      "arabic": "اشْتَرَتِ الشَّرِكَةُ طَابِعَةً جَدِيدَةً لِلْمَكْتَبِ.",
      "metadata": { "difficulty": 1, "tags": ["printer", "office equipment", "colleagues", "instructions"] }
    },
    {
      "id": "work-b1-030",
      "arabic": "تَعْمَلُ لُبْنَى فِي مَطْعَمٍ وَتَخْدِمُ الزَّبَائِنَ.",
      "metadata": { "difficulty": 1, "tags": ["waitress", "restaurant", "customer service", "tip"] }
    },
    {
      "id": "work-b1-031",
      "arabic": "يَعْمَلُ زَيَّادٌ مِنَ الْبَيْتِ ثَلَاثَةَ أَيَّامٍ فِي الْأُسْبُوعِ.",
      "metadata": { "difficulty": 1, "tags": ["remote work", "home office", "internet", "work routine"] }
    },
    {
      "id": "work-b1-032",
      "arabic": "أَخَذَتْ لَانَا فَتْرَةَ اسْتِرَاحَةٍ فِي الْعَاشِرَةِ صَبَاحًا.",
      "metadata": { "difficulty": 1, "tags": ["break", "coffee", "colleagues", "office"] }
    },
    {
      "id": "work-b1-033",
      "arabic": "يَعْمَلُ سُلَيْمَانُ فِي صَيْدَلِيَّةٍ كَمُسَاعِدٍ لِلصَّيْدَلَانِيِّ.",
