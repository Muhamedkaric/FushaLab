    {
      "id": "religion-b1-030",
      "arabic": "الدُّعَاءُ عِبَادَةٌ عَظِيمَةٌ وَهُوَ مُخُّ الْعِبَادَةِ كَمَا قَالَ النَّبِيُّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ [رَوَاهُ التِّرْمِذِيُّ، وَحَسَّنَهُ الْأَلْبَانِيُّ].",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "dua",
          "supplication",
          "dhikr",
          "ibadah"
        ]
      }
    },
    {
      "id": "religion-b1-031",
      "arabic": "عَنْ عُمَرَ بْنِ الْخَطَّابِ رَضِيَ اللَّهُ عَنْهُ، قَالَ النَّبِيُّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ: «إِنَّمَا الْأَعْمَالُ بِالنِّيَّاتِ» [رَوَاهُ الْبُخَارِيُّ فِي كِتَابِ بَدْءِ الْوَحْيِ، حَدِيثُ رَقْمِ ١].",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "Ikhlas",
          "Hadith",
          "Intentions"
        ]
      }
    },
    {
      "id": "religion-b1-032",
      "arabic": "قَالَ النَّبِيُّ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ: «عَلَيْكُمْ بِالصِّدْقِ، فَإِنَّ الصِّدْقَ يَهْدِي إِلَى الْبِرِّ» [رَوَاهُ مُسْلِمٌ فِي كِتَابِ الْبِرِّ وَالصِّلَةِ، حَدِيثُ رَقْمِ ٢٦٠٧].",
      "metadata": {
        "difficulty": 1,
        "tags": [
          "Adab",
          "Hadith",
          "Honesty"
        ]
      }
    },
    {
      "id": "religion-b1-033",
      "arabic": "الصَّلَاةُ هِيَ الرُّكْنُ الثَّانِي مِنْ أَرْكَانِ الْإِسْلَامِ الْخَمْسَةِ الْعَظِيمَةِ.",
